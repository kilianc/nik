# Ignore everything by default
*

# Unignore directories (required for nested file matching)
!*/

# Track Go source and dependencies
!*.go
!go.mod
!go.sum

# Track SQL and sqlc config
!internal/db/schema.sql
!internal/queries/*.sql

# Track templates
!*.tmpl

# Track build
!Makefile
!internal/shell/Dockerfile

# Track docs
!.gitignore
!*.md
!AGENTS.md
!config.example.yaml

# Track scripts and service files
!*.sh
!*.service
!*.timer

# Track GitHub Actions workflows
!.github/workflows/*.yaml
!.github/workflows/*.yml

# Always ignore
.cursor/
TODO.md
workspace/
workbench/
